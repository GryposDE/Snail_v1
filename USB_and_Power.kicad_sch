		)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left top)
		)
		(uuid "7513e5df-bf9f-4798-b529-f8992d40c9ed")
	)
	(text_box "We use a 18650 battery with integrated protection circuit.\nThis is why the dimensions a bit off.\nlength   = 68.90 mm ± 0.15 mm\ndiameter = 18,40 mm ± 0,1 mm"
		(exclude_from_sim no)
		(at 127 35.56 0)
		(size 45.72 12.7)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
