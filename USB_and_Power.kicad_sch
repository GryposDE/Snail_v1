	(text_box "ILIM: 1.18kR to have up to 1.3A input current\nISET: 1kR to have up to 1A charging current\nTMR: we dont use the Timer\nnCR: we always allow charging\nITERM: use default 10% termination current (100 mA)\n"
		(exclude_from_sim no)
		(at 17.78 41.91 0)
		(size 57.15 12.7)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left top)
		)
		(uuid "407b29a8-6918-43c7-a18d-0aca6605cd88")
	)
	(text_box "FUSB303BTMX\n\n- ADDR/ORIENT: floating -> GPIO-Mode\n- VBUS_DET: can handle up to 28V\n- PORT/DEBUG_N: low -> system is USB sink"
		(exclude_from_sim no)
		(at 92.71 160.02 0)
		(size 48.26 13.97)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
